# OpenAI x UTS Hackathon - local defaults
# Copy to .env and fill real secrets locally.

# Backend
API_PORT=4000
CORS_ORIGINS=http://localhost:3000
# Colon-separated list of directories the scanner may read. Defaults to this
# repo root when unset.
SCAN_ALLOWED_ROOTS=
# Directory reserved for GitPython worktree operations.
SCAN_WORKTREE_ROOT=.worktrees

# OpenAI - required before starting a scan.
OPENAI_API_KEY=
# Optional Agents SDK settings. Leave unset to use SDK defaults.
OPENAI_AGENT_MODEL=
OPENAI_PROJECT=
OPENAI_ORG_ID=
OPENAI_BASE_URL=

# Optional GitHub PR creation. Disabled unless token and repository are both set.
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_BASE_BRANCH=main

# Optional local infra
REDIS_URL=redis://localhost:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
