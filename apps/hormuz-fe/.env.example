# Copy to `.env.local` only when overriding local defaults.
# By default Vite serves the app on http://localhost:3000 and proxies:
# - HTTP API requests from /api/* to http://localhost:4000
# - WebSocket scans from /ws/* to ws://localhost:4000

# VITE_WS_URL=ws://localhost:4000/ws/scan

# Force mock mode instead of connecting to the backend.
# VITE_USE_MOCK=1

# `fast` halves all mock-server timings (handy for video recording).
# VITE_MOCK_SPEED=fast
