# Copy to `.env.local` and uncomment to point at a real backend.
# Leaving these unset enables the in-process mock server automatically.

# VITE_WS_URL=ws://localhost:8000/ws

# Force mock mode even when a URL is configured.
# VITE_USE_MOCK=1

# `fast` halves all mock-server timings (handy for video recording).
# VITE_MOCK_SPEED=fast
