{
  "openapi": "3.1.0",
  "info": {
    "title": "Hormuz API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Api Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/scans/preview": {
      "post": {
        "tags": [
          "scan"
        ],
        "summary": "Preview Scan",
        "operationId": "preview_scan_api_scans_preview_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScanRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanSummary"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Finding": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "agent": {
            "type": "string",
            "title": "Agent"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "violation_type": {
            "type": "string",
            "title": "Violation Type"
          },
          "severity": {
            "$ref": "#/components/schemas/Severity"
          },
          "file_path": {
            "type": "string",
            "title": "File Path"
          },
          "line": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Line"
          },
          "context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "snippet": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Snippet"
          },
          "regulations": {
            "items": {
              "$ref": "#/components/schemas/RegulationRef"
            },
            "type": "array",
            "title": "Regulations"
          },
          "recommendation": {
            "type": "string",
            "title": "Recommendation"
          },
          "remediation_hint": {
            "type": "string",
            "title": "Remediation Hint"
          }
        },
        "type": "object",
        "required": [
          "id",
          "agent",
          "category",
          "violation_type",
          "severity",
          "file_path",
          "title",
          "description",
          "recommendation",
          "remediation_hint"
        ],
        "title": "Finding"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RegulationRef": {
        "properties": {
          "framework": {
            "type": "string",
            "enum": [
              "GDPR",
              "APP"
            ],
            "title": "Framework"
          },
          "clause": {
            "type": "string",
            "title": "Clause"
          },
          "summary": {
            "type": "string",
            "title": "Summary"
          }
        },
        "type": "object",
        "required": [
          "framework",
          "clause",
          "summary"
        ],
        "title": "RegulationRef"
      },
      "ScanRequest": {
        "properties": {
          "repo_path": {
            "type": "string",
            "minLength": 1,
            "title": "Repo Path"
          }
        },
        "type": "object",
        "required": [
          "repo_path"
        ],
        "title": "ScanRequest"
      },
      "ScanSummary": {
        "properties": {
          "score": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Score"
          },
          "total_findings": {
            "type": "integer",
            "title": "Total Findings"
          },
          "counts_by_severity": {
            "additionalProperties": {
              "type": "integer"
            },
            "propertyNames": {
              "$ref": "#/components/schemas/Severity"
            },
            "type": "object",
            "title": "Counts By Severity"
          },
          "findings": {
            "items": {
              "$ref": "#/components/schemas/Finding"
            },
            "type": "array",
            "title": "Findings"
          }
        },
        "type": "object",
        "required": [
          "score",
          "total_findings",
          "counts_by_severity",
          "findings"
        ],
        "title": "ScanSummary"
      },
      "Severity": {
        "type": "string",
        "enum": [
          "critical",
          "high",
          "medium",
          "low"
        ],
        "title": "Severity"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
